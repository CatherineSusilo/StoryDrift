# Server Configuration
PORT=3001
NODE_ENV=development

# Database (SQLite local)
# The database file will be created automatically in the prisma/ directory
DATABASE_URL="file:./storydrift.db"

# Auth0 Configuration
APP_BASE_URL=http://localhost:5173
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.storydrift.app
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
# Generate with: openssl rand -hex 32
AUTH0_SECRET=your_64_character_random_string

# CORS
CORS_ORIGIN=http://localhost:5173

# AI Services
# Get your Gemini API key from: https://aistudio.google.com/app/apikey
# Used for legacy story generation
GEMINI_API_KEY=your_gemini_api_key_here

# Claude API (Anthropic) — used for story generation flow (Node 4 + Node 5)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Fal.ai — used for scene image generation (Node 6, Flux model)
# Get your key from: https://fal.ai/dashboard
FAL_API_KEY=your_fal_api_key_here

# ElevenLabs — voice narration (Node 7)
# Get your key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Optional: override default narrator voice ID
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
