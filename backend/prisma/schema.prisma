// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  auth0Id   String   @unique
  email     String   @unique
  name      String?
  picture   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  children Child[]
}

model Child {
  id          String    @id @default(cuid())
  userId      String
  name        String
  age         Int
  dateOfBirth DateTime?
  avatar      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sleepSessions      SleepSession[]
  storySessions      StorySession[]
  preferences        ChildPreferences?
  storyGraphSessions StoryGraphSession[]

  @@index([userId])
}

model ChildPreferences {
  id                  String   @id @default(cuid())
  childId             String   @unique
  storytellingTone    String   @default("calming")
  favoriteThemes      String   @default("[]") // JSON array stored as string
  defaultInitialState String   @default("normal")
  personality         String?
  favoriteMedia       String?
  parentGoals         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model StorySession {
  id                String    @id @default(cuid())
  childId           String
  storyTitle        String
  storyContent      String
  parentPrompt      String
  storytellingTone  String
  initialState      String
  startTime         DateTime  @default(now())
  endTime           DateTime?
  duration          Int?
  sleepOnsetTime    DateTime?
  completed         Boolean   @default(false)

  initialDriftScore Int      @default(0)
  finalDriftScore   Int      @default(0)
  driftScoreHistory String   @default("[]") // JSON array stored as string

  imagePrompts      String?  // JSON stored as string
  generatedImages   String   @default("[]") // JSON array stored as string
  audioUrls         String   @default("[]") // JSON array of per-paragraph MP3 URLs

  modelUsed         String?
  targetDuration    Int?     // minutes: 10 short / 15 medium / 20 long
  minigameFrequency String?  // none | every_5th | every_3rd | every_paragraph

  // Vitals summary for this story session (populated when story ends)
  avgHeartRate      Float?
  avgBreathingRate  Float?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  child       Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  storyVitals StoryVitals?

  @@index([childId])
  @@index([startTime])
}

/// Per-story vitals data captured via SmartSpectra SDK.
/// One row per story session; snapshots are stored as a JSON array.
model StoryVitals {
  id               String   @id @default(cuid())
  storySessionId   String   @unique
  childId          String
  avgHeartRate     Float    @default(0)
  avgBreathingRate Float    @default(0)
  minHeartRate     Float    @default(0)
  maxHeartRate     Float    @default(0)
  /// JSON array of { timestamp, heartRate, breathingRate, confidence }
  snapshots        String   @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  storySession StorySession @relation(fields: [storySessionId], references: [id], onDelete: Cascade)

  @@index([childId])
}

model SleepSession {
  id               String    @id @default(cuid())
  childId          String
  storySessionId   String?
  bedtime          DateTime
  wakeupTime       DateTime?
  duration         Int?
  quality          String?
  notes            String?

  timeToSleep      Int?
  nightWakings     Int      @default(0)
  sleepEfficiency  Float?

  weatherCondition String?
  roomTemperature  Float?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([bedtime])
}

model StoryGraphSession {
  id         String    @id
  childId    String
  mode       String    // 'bedtime' | 'educational'
  state      String    // JSON-serialised GraphState
  lessonName String?
  startTime  DateTime  @default(now())
  endTime    DateTime?
  completed  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
  @@index([startTime])
}
